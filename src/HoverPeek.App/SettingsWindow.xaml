<Window x:Class="HoverPeek.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:HoverPeek.Core.Localization;assembly=HoverPeek.Core"
        Title="{x:Static loc:Strings.SettingsWindowTitle}"
        Width="600"
        Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- 懸停行為 -->
            <TabItem Header="{x:Static loc:Strings.TabHoverBehavior}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="{x:Static loc:Strings.LabelHoverDelay}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="HoverDelayTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelJitterTolerance}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="JitterToleranceTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelAutoCloseDelay}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="AutoCloseDelayTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.DescriptionLabel}" FontSize="11" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="{x:Static loc:Strings.DescHoverDelay}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescJitterTolerance}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescAutoCloseDelay}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 預覽視窗 -->
            <TabItem Header="{x:Static loc:Strings.TabPreviewWindow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="{x:Static loc:Strings.LabelWindowWidth}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="WindowWidthTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelWindowHeight}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="WindowHeightTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <CheckBox x:Name="CenterWindowCheckBox" Content="{x:Static loc:Strings.LabelCenterWindow}" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelFadeInDuration}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="FadeInDurationTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelFadeOutDuration}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="FadeOutDurationTextBox" Width="150" HorizontalAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 圖片預覽 -->
            <TabItem Header="{x:Static loc:Strings.TabImagePreview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="{x:Static loc:Strings.LabelImageMaxDimension}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="ImageMaxDimensionTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <CheckBox x:Name="EnableGifAnimationCheckBox" Content="{x:Static loc:Strings.LabelEnableGifAnimation}" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.DescriptionLabel}" FontSize="11" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="{x:Static loc:Strings.DescImageScale}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescGifStatic}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 文字預覽 -->
            <TabItem Header="{x:Static loc:Strings.TabTextPreview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="{x:Static loc:Strings.LabelTextMaxFileSize}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TextMaxFileSizeTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelTextMaxLines}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TextMaxLinesTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelTextFontSize}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="TextFontSizeTextBox" Width="150" HorizontalAlignment="Left" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelTextFontFamily}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="TextFontFamilyComboBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <ComboBoxItem Content="Consolas"/>
                            <ComboBoxItem Content="Courier New"/>
                            <ComboBoxItem Content="Cascadia Code"/>
                            <ComboBoxItem Content="JetBrains Mono"/>
                            <ComboBoxItem Content="Fira Code"/>
                        </ComboBox>

                        <CheckBox x:Name="EnableMarkdownRenderingCheckBox" Content="{x:Static loc:Strings.LabelEnableMarkdownRendering}" Margin="0,0,0,8"/>
                        <CheckBox x:Name="EnableSyntaxHighlightingCheckBox" Content="{x:Static loc:Strings.LabelEnableSyntaxHighlighting}" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.DescriptionLabel}" FontSize="11" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="{x:Static loc:Strings.DescMarkdownRendering}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescSyntaxHighlighting}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 影片預覽 -->
            <TabItem Header="{x:Static loc:Strings.TabVideoPreview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <CheckBox x:Name="VideoAutoPlayCheckBox" Content="{x:Static loc:Strings.LabelVideoAutoPlay}" Margin="0,0,0,8"/>
                        <CheckBox x:Name="VideoMutedCheckBox" Content="{x:Static loc:Strings.LabelVideoMuted}" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.DescriptionLabel}" FontSize="11" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="{x:Static loc:Strings.DescVideoThumbnail}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescVideoMuted}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 壓縮檔預覽 -->
            <TabItem Header="{x:Static loc:Strings.TabArchivePreview}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <CheckBox x:Name="ArchiveAutoExpandCheckBox" Content="{x:Static loc:Strings.LabelArchiveAutoExpand}" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.DescriptionLabel}" FontSize="11" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="{x:Static loc:Strings.DescArchiveAutoExpand}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescArchiveManual}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 啟動設定 -->
            <TabItem Header="{x:Static loc:Strings.TabStartup}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="{x:Static loc:Strings.LabelStartWithWindows}" Margin="0,0,0,16"/>

                        <TextBlock Text="{x:Static loc:Strings.LabelLanguage}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="LanguageComboBox" Width="200" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <ComboBoxItem Content="繁體中文" Tag="zh-TW"/>
                            <ComboBoxItem Content="English" Tag="en"/>
                        </ComboBox>

                        <TextBlock Text="{x:Static loc:Strings.DescriptionLabel}" FontSize="11" Foreground="#666" Margin="0,8,0,4"/>
                        <TextBlock Text="{x:Static loc:Strings.DescStartup}" FontSize="11" Foreground="#666"/>
                        <TextBlock Text="{x:Static loc:Strings.DescTrayMinimize}" FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="ResetButton" Content="{x:Static loc:Strings.ButtonReset}" Padding="16,8" Margin="0,0,8,0" Click="OnResetClick"/>
            <Button x:Name="CancelButton" Content="{x:Static loc:Strings.ButtonCancel}" Padding="16,8" Margin="0,0,8,0" Click="OnCancelClick"/>
            <Button x:Name="SaveButton" Content="{x:Static loc:Strings.ButtonSave}" Padding="16,8" Click="OnSaveClick" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
