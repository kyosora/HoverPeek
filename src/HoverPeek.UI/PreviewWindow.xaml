<Window x:Class="HoverPeek.UI.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:loc="clr-namespace:HoverPeek.Core.Localization;assembly=HoverPeek.Core"
        Title="HoverPeek"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Width="800"
        Height="600"
        Opacity="0">
    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
        <Storyboard x:Key="FadeOut">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="1" To="0" Duration="0:0:0.1"/>
        </Storyboard>
    </Window.Resources>

    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="#F0F0F0"
            BorderBrush="#C0C0C0"
            BorderThickness="1"
            Padding="12"
            MouseLeave="OnMouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                            ShadowDepth="4"
                            Opacity="0.3"
                            Color="Black"/>
        </Border.Effect>

        <Grid>
            <Image x:Name="ImagePreview"
                   Visibility="Collapsed"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Stretch="Uniform"
                   Margin="4"/>

            <StackPanel x:Name="ArchivePanel"
                        Visibility="Collapsed"
                        MinWidth="300">
                <TextBlock x:Name="ArchiveTitle"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"
                           Foreground="Black"
                           TextWrapping="Wrap"
                           MaxWidth="800"/>

                <Button x:Name="ExpandButton"
                        Content="{x:Static loc:Strings.ExpandFileList}"
                        Padding="12,6"
                        Margin="0,0,0,8"
                        Click="OnExpandClick"
                        HorizontalAlignment="Left"/>

                <!-- 使用 Grid 並排顯示檔案列表和圖片預覽 -->
                <Grid x:Name="ContentGrid"
                      Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- 檔案列表（左側） -->
                        <ColumnDefinition Width="*"/>     <!-- 圖片預覽（右側） -->
                    </Grid.ColumnDefinitions>

                    <ListView x:Name="FileListView"
                              Grid.Column="0"
                              MaxHeight="500"
                              MinWidth="420"
                              SelectionMode="Single"
                              MouseMove="OnFileListMouseMove">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{x:Static loc:Strings.HeaderName}" Width="250">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static loc:Strings.HeaderSize}" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SizeText}" TextAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static loc:Strings.HeaderType}" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TypeIcon}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Image x:Name="InnerImagePreview"
                           Grid.Column="1"
                           Visibility="Collapsed"
                           MaxWidth="500"
                           MaxHeight="500"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Stretch="Uniform"
                           Margin="12,0,0,0"/>
                </Grid>
            </StackPanel>

            <vlc:VideoView x:Name="VideoPlayer"
                           Visibility="Collapsed"
                           Margin="4"/>

            <!-- 純文字預覽（舊版，不使用語法高亮時） -->
            <ScrollViewer x:Name="TextPreviewScroll"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Margin="4">
                <StackPanel>
                    <TextBlock x:Name="TextPreviewHeader"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#666"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="TextPreviewContent"
                             FontFamily="Consolas, Courier New, Monospace"
                             FontSize="11"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Markdown HTML 預覽（使用 WebView2） -->
            <wv2:WebView2 x:Name="MarkdownWebView"
                          Visibility="Collapsed"
                          Margin="4"/>

            <!-- 程式碼語法高亮預覽（使用 AvalonEdit） -->
            <Grid x:Name="CodeEditorPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="CodePreviewHeader"
                           Grid.Row="0"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#666"
                           Margin="4,4,4,8"
                           TextWrapping="Wrap"/>
                <avalonEdit:TextEditor x:Name="CodeEditor"
                                       Grid.Row="1"
                                       FontFamily="Consolas, Courier New, Monospace"
                                       FontSize="11"
                                       IsReadOnly="True"
                                       ShowLineNumbers="True"
                                       Margin="4"
                                       Background="White"
                                       VerticalScrollBarVisibility="Auto"
                                       HorizontalScrollBarVisibility="Auto"/>
            </Grid>

            <TextBlock x:Name="UnsupportedText"
                       Visibility="Collapsed"
                       Text="{x:Static loc:Strings.UnsupportedFileType}"
                       FontSize="12"
                       Foreground="#888"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Padding="20"/>
        </Grid>
    </Border>
</Window>
